Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.boot_timeout = 300

  def provision_common(vm)
    vm.vm.provision "shell", privileged: true, inline: <<-SHELL
      apt-get install -y python3 python3-pip
      cp /vagrant/scripts/* /home/vagrant/
      chown vagrant:vagrant /home/vagrant/*.py
      chmod +x /home/vagrant/*.py
    SHELL
  end

  config.vm.define "p1" do |p1|
    p1.vm.hostname = "p1"
    p1.vm.network "private_network", ip: "192.168.56.11"
    provision_common(p1)
    p1.vm.provision "shell", privileged: true, inline: <<-SHELL
      cp /vagrant/files/* /home/vagrant/
      chown vagrant:vagrant /home/vagrant/mainfile.txt /home/vagrant/coveredfile.txt
      cat >/usr/local/bin/run-p1-pass <<'EOF'
#!/bin/bash
cd /home/vagrant
exec python3 ./p1.py --main-file ./mainfile.txt --covert-file ./coveredfile.txt --dst-ip 192.168.56.12 --dst-port 9000 --interval 1.0 --stats-file ./p1_stats_passthrough.json
EOF
      cat >/usr/local/bin/run-p1-jitter <<'EOF'
#!/bin/bash
cd /home/vagrant
exec python3 ./p1.py --main-file ./mainfile.txt --covert-file ./coveredfile.txt --dst-ip 192.168.56.12 --dst-port 9000 --interval 1.0 --stats-file ./p1_stats_jitter.json
EOF
      cat >/usr/local/bin/run-p1-normalize <<'EOF'
#!/bin/bash
cd /home/vagrant
exec python3 ./p1.py --main-file ./mainfile.txt --covert-file ./coveredfile.txt --dst-ip 192.168.56.12 --dst-port 9000 --interval 1.0 --stats-file ./p1_stats_normalize.json
EOF
      chmod +x /usr/local/bin/run-p1-pass /usr/local/bin/run-p1-jitter /usr/local/bin/run-p1-normalize
      cat >>/home/vagrant/.bash_aliases <<'EOF'
alias p1-pass='run-p1-pass'
alias p1-jitter='run-p1-jitter'
alias p1-normalize='run-p1-normalize'
EOF
      chown vagrant:vagrant /home/vagrant/.bash_aliases
    SHELL
  end

  config.vm.define "uz" do |uz|
    uz.vm.hostname = "uz"
    uz.vm.network "private_network", ip: "192.168.56.12"
    provision_common(uz)
    uz.vm.provision "shell", privileged: true, inline: <<-SHELL
      cat >/usr/local/bin/run-uz-pass <<'EOF'
#!/bin/bash
cd /home/vagrant
exec python3 ./uz.py --listen-ip 0.0.0.0 --listen-port 9000 --forward-ip 192.168.56.13 --forward-port 9001 --mode passthrough --stats-file ./uz_stats.json
EOF
      cat >/usr/local/bin/run-uz-jitter <<'EOF'
#!/bin/bash
cd /home/vagrant
exec python3 ./uz.py --listen-ip 0.0.0.0 --listen-port 9000 --forward-ip 192.168.56.13 --forward-port 9001 --mode jitter --jitter-max-delay 0.35 --stats-file ./uz_stats.json
EOF
      cat >/usr/local/bin/run-uz-normalize <<'EOF'
#!/bin/bash
cd /home/vagrant
exec python3 ./uz.py --listen-ip 0.0.0.0 --listen-port 9000 --forward-ip 192.168.56.13 --forward-port 9001 --mode normalize --normalize-quantum 0.1 --stats-file ./uz_stats.json
EOF
      chmod +x /usr/local/bin/run-uz-pass /usr/local/bin/run-uz-jitter /usr/local/bin/run-uz-normalize
      cat >>/home/vagrant/.bash_aliases <<'EOF'
alias uz-pass='run-uz-pass'
alias uz-jitter='run-uz-jitter'
alias uz-normalize='run-uz-normalize'
EOF
      chown vagrant:vagrant /home/vagrant/.bash_aliases
    SHELL
  end

  config.vm.define "p2" do |p2|
    p2.vm.hostname = "p2"
    p2.vm.network "private_network", ip: "192.168.56.13"
    provision_common(p2)
    p2.vm.provision "shell", privileged: true, inline: <<-SHELL
      cat >/usr/local/bin/run-p2-pass <<'EOF'
#!/bin/bash
cd /home/vagrant
exec python3 ./p2.py --listen-ip 0.0.0.0 --listen-port 9001 --interval 1.0 --covert-output ./covert_passthrough.txt --legit-output ./main_passthrough.txt --stats-file ./p2_stats_passthrough.json
EOF
      cat >/usr/local/bin/run-p2-jitter <<'EOF'
#!/bin/bash
cd /home/vagrant
exec python3 ./p2.py --listen-ip 0.0.0.0 --listen-port 9001 --interval 1.0 --covert-output ./covert_jitter.txt --legit-output ./main_jitter.txt --stats-file ./p2_stats_jitter.json
EOF
      cat >/usr/local/bin/run-p2-normalize <<'EOF'
#!/bin/bash
cd /home/vagrant
exec python3 ./p2.py --listen-ip 0.0.0.0 --listen-port 9001 --interval 1.0 --covert-output ./covert_normalize.txt --legit-output ./main_normalize.txt --stats-file ./p2_stats_normalize.json
EOF
      chmod +x /usr/local/bin/run-p2-pass /usr/local/bin/run-p2-jitter /usr/local/bin/run-p2-normalize
      cat >>/home/vagrant/.bash_aliases <<'EOF'
alias p2-pass='run-p2-pass'
alias p2-jitter='run-p2-jitter'
alias p2-normalize='run-p2-normalize'
EOF
      chown vagrant:vagrant /home/vagrant/.bash_aliases
    SHELL
  end
end
